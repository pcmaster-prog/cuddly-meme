APP_NAME="DecorArte Media Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DATABASE (PostgreSQL / Supabase Connection)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=decorarte_hub
DB_USERNAME=decorarte_admin
DB_PASSWORD=SecretPassword2027

# BROADCAST & QUEUES
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

# REDIS (Caching and Video Rendering Pipeline Queue)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# CLOUDFLARE R2 BUCKET STORAGE (S3 Compatible API)
AWS_ACCESS_KEY_ID=your_cloudflare_r2_access_key
AWS_SECRET_ACCESS_KEY=your_cloudflare_r2_secret_key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=decorarte-media-hub
AWS_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# AI ENGINE API TOKENS
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OMNI_API_KEY=your_omni_api_key_here
LTX_API_KEY=your_ltx_api_key_here
SEEDANCE_API_KEY=your_seedance_api_key_here
